---
import Layout from "src/layouts/Layout.astro";
import Sidebar from "../components/ui/Sidebar.astro";
import "../styles/global.css";
---

<Layout>
  <Sidebar />
  <main class="pb-24 md:pb-0 md:ml-20 p-6 md:p-10 w-full max-w-7xl mx-auto">
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-3xl font-black">Activity Log</h1>
      <button
        id="clear-all-btn"
        class="text-xs font-bold uppercase tracking-widest text-gray-500 hover:text-red-500 transition-colors"
      >
        Clear All History
      </button>
    </div>
    <div class="bg-gray-900 rounded-xl border border-gray-800 overflow-hidden">
      <table class="w-full text-left">
        <thead class="bg-gray-800 text-gray-400 uppercase text-xs">
          <tr>
            <th class="px-6 py-4 text-accent">Activity</th>
            <th class="px-6 py-4">Duration</th>
            <th class="px-6 py-4">Time</th>
            <th class="px-6 py-4 text-right">Action</th>
          </tr>
        </thead>
        <tbody id="log-table-body"></tbody>
      </table>
    </div>
  </main>

  <script>
    import { logStore, deleteLog, clearAllLogs } from "../lib/logStore"; // Import the cloud delete function

    const tableBody = document.getElementById("log-table-body");

    logStore.subscribe((logs) => {
      if (!tableBody) return;
      const allLogs = [...logs].reverse();

      tableBody.innerHTML = allLogs
        .map(
          (log) => `
    <tr class="border-t border-gray-800 hover:bg-gray-800/50 transition-colors">
      <td class="px-6 py-4 font-bold text-gray-100">${log.activity || "Focus Session"}</td>
      <td class="px-6 py-4 font-mono text-accent text-sm">${log.duration}</td>
      <td class="px-6 py-4 text-xs text-gray-500">${log.timestamp}</td>
      <td class="px-6 py-4 text-right">
        <button data-id="${log.id}" class="delete-log-btn text-gray-600 hover:text-red-500 transition-colors">
          <span class="material-symbols-rounded">delete</span>
        </button>
      </td>
    </tr>
  `,
        )
        .join("");

      // Attach the cloud delete event
      tableBody.querySelectorAll(".delete-log-btn").forEach((btn) => {
        btn.onclick = () => {
          const id = btn.getAttribute("data-id");
          if (confirm("Delete this log entry forever?")) {
            deleteLog(id); // This handles both local AND Supabase
          }
        };
      });
    });
    const clearBtn = document.getElementById("clear-all-btn");
    clearBtn.onclick = () => {
      if (
        confirm(
          "This will permanently wipe your entire cloud history. Proceed?",
        )
      ) {
        clearAllLogs();
      }
    };
  </script>
</Layout>
